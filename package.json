{
  "name": "2careai-voiceai",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspace=packages/server",
    "db:migrate": "psql $DATABASE_URL -f packages/server/src/db/schema.sql",
    "db:seed": "psql $DATABASE_URL -f packages/server/src/db/seed.sql",
    "campaign:worker": "npx tsx campaigns/worker.ts"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
